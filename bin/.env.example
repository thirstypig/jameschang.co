# Env-var matrix for /now data-feed sync scripts.
#
# Local use: cp this file to .env (or set the vars in your shell), then
# `python3 bin/update-{whoop,spotify,plex,projects}.py` will run with the
# same surface as the GitHub Actions runners.
#
# In CI these are GitHub Secrets; bin/check-feed-health.py also reads
# GH_TOKEN provided by the workflow's github.token.

# WHOOP — daily cron via .github/workflows/whoop-sync.yml
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Passphrase used to AES-encrypt .whoop-token.enc. Generate via
# bin/whoop-auth.sh + bin/whoop-encrypt.sh, then store in GitHub Secrets.
WHOOP_TOKEN_KEY=

# Spotify — every 30 min via .github/workflows/spotify-sync.yml
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Plain refresh token (Spotify tokens do not rotate). Obtain via bin/spotify-auth.sh.
SPOTIFY_REFRESH_TOKEN=

# Plex — every 6 hours via .github/workflows/plex-sync.yml
# PLEX_URL is a relay URL (https://{ip-dashed}.{server-hash}.plex.direct:{port}).
PLEX_URL=
PLEX_TOKEN=

# Projects (per-project TLDR + GitHub shipping) — daily 7 AM PT via projects-sync.yml
# Fine-grained PAT with Contents:Read on every private repo listed in
# bin/projects-config.json's shipping_repos. Expires every 90 days.
TLDR_FETCH_TOKEN=

# Trakt — DISABLED (workflow renamed to trakt-sync.yml.disabled). Kept for re-enable.
# TRAKT_CLIENT_ID=
# TRAKT_CLIENT_SECRET=
# TRAKT_TOKEN_KEY=

# Public feeds (MLB, Goodreads, FBST) — every 6 hours via public-feeds-sync.yml.
# All endpoints are unauthenticated; no env vars required.

# Staleness monitor — bin/check-feed-health.py
# Set DRY_RUN=1 for cold local runs so the script doesn't open / close real GitHub issues.
# DRY_RUN=1
