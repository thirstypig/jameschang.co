{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://jameschang.co/bucketlist.schema.json",
  "title": "BucketList",
  "type": "object",
  "required": ["items", "last_updated"],
  "additionalProperties": false,
  "properties": {
    "items": { "type": "array", "items": { "$ref": "#/definitions/item" } },
    "last_updated": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "item": {
      "type": "object",
      "required": ["id", "title", "note", "status", "completed_date", "priority", "difficulty"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "note": { "type": "string" },
        "status": { "enum": ["todo", "done"] },
        "completed_date": { "oneOf": [{ "type": "null" }, { "type": "string", "format": "date" }] },
        "priority": { "oneOf": [{ "type": "null" }, { "enum": ["high", "medium", "low"] }] },
        "difficulty": { "oneOf": [{ "type": "null" }, { "enum": ["easy", "hard"] }] }
      }
    }
  }
}
